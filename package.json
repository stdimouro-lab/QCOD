{
  "name": "qcod",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Quality Control Operations Dashboard — Martinsburg VA Medical Center",
  "scripts": {
    "generate:excel": "node scripts/generate-excel.js",
    "sync:data": "node scripts/sync-data.js",
    "import:assets": "node scripts/import-assets.js",
    "import:sections": "node scripts/import-section-progress.js",
    "dev": "npm run dev --prefix web",
    "build:web": "npm run build --prefix web",
    "install:all": "npm install && npm install --prefix web",
    "setup:source-folders": "powershell -ExecutionPolicy Bypass -File scripts/setup-private-source-folders.ps1"
  },
  "dependencies": {
    "exceljs": "^4.4.0"
  }
}
